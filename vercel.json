{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.ts"
    }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/v1/internal/cron/reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/v1/internal/cron/renewals",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/v1/internal/cron/retries",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/v1/internal/cron/expiry",
      "schedule": "*/30 * * * *"
    }
  ]
}
