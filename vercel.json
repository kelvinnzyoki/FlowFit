{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.ts"
    }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "crons": [
  { "path": "/api/cron/reminders", "schedule": "0 8 * * *"  },
  { "path": "/api/cron/renew",     "schedule": "0 1 * * *"  },
  { "path": "/api/cron/retry",     "schedule": "0 3 * * *"  },
  { "path": "/api/cron/expire",    "schedule": "0 2 * * *"  }
  ]
}
