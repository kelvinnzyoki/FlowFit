// ============================================================
// FLOWFIT — PRODUCTION PRISMA SCHEMA  v3
// Adds: M-Pesa transaction tracking, renewal metadata,
//       grace period, provider field, cron lock table
// ============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  GRACE_PERIOD   // NEW: M-Pesa grace period (3 days after expiry)
  CANCELLED
  EXPIRED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAUSED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum PaymentProvider {
  STRIPE
  MPESA
  MANUAL
}

enum SubscriptionEvent {
  CREATED
  TRIAL_STARTED
  TRIAL_CONVERTED
  TRIAL_EXPIRED
  ACTIVATED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  UPGRADED
  DOWNGRADE_SCHEDULED
  DOWNGRADE_APPLIED
  CANCEL_SCHEDULED
  CANCELLED
  REACTIVATED
  EXPIRED
  REFUNDED
  WEBHOOK_RECEIVED
  // NEW M-Pesa events
  MPESA_STK_INITIATED
  MPESA_STK_SUCCESS
  MPESA_STK_FAILED
  MPESA_RETRY_SCHEDULED
  GRACE_PERIOD_STARTED
  GRACE_PERIOD_EXPIRED
  RENEWAL_REMINDER_SENT
}

enum MpesaTransactionStatus {
  PENDING      // STK Push sent, awaiting callback
  SUCCESS      // Payment confirmed
  FAILED       // User cancelled or timeout
  CANCELLED    // User explicitly cancelled
  TIMEOUT      // No callback received within window
}

// ============================================================
// CORE USER & AUTH
// ============================================================

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String
  name            String?
  role            String    @default("USER")
  isEmailVerified Boolean   @default(false)
  lastLogin       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  stripeCustomerId String? @unique

  // M-Pesa phone number for auto-renewal STK pushes
  mpesaPhone String?

  profile          Profile?
  enrollments      ProgramEnrollment[]
  workoutLogs      WorkoutLog[]
  metrics          UserMetrics[]
  userAchievements UserAchievement[]
  subscriptions    Subscription[]
  refreshTokens    RefreshToken[]
  mpesaTransactions MpesaTransaction[]

  @@map("users")
}

model Profile {
  id                  String    @id @default(uuid())
  bio                 String?
  firstName           String?
  lastName            String?
  dateOfBirth         DateTime?
  gender              String?
  height              Float?
  weight              Float?
  targetWeight        Float?
  fitnessGoal         String?
  fitnessLevel        String?
  timezone            String?
  avatarUrl           String?
  onboardingCompleted Boolean   @default(false)
  isPublic            Boolean   @default(true)
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ============================================================
// PLANS
// ============================================================

model Plan {
  id          String  @id @default(uuid())
  slug        String  @unique
  name        String
  description String?

  monthlyPriceCents Int @default(0)
  yearlyPriceCents  Int @default(0)

  // M-Pesa prices (in KES, stored as cents/smallest unit)
  mpesaMonthlyKes Int @default(0)
  mpesaYearlyKes  Int @default(0)

  stripePriceIdMonthly String? @unique
  stripePriceIdYearly  String? @unique

  trialDays Int @default(0)

  maxWorkoutsPerMonth  Int?
  maxPrograms          Int?
  hasAdvancedAnalytics Boolean @default(false)
  hasPersonalCoaching  Boolean @default(false)
  hasNutritionTracking Boolean @default(false)
  hasOfflineAccess     Boolean @default(false)

  features     Json    @default("[]")
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)
  isPopular    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

// ============================================================
// SUBSCRIPTIONS
// ============================================================

model Subscription {
  id     String @id @default(uuid())
  userId String
  planId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  status   SubscriptionStatus @default(TRIALING)
  interval BillingInterval    @default(MONTHLY)

  // Payment provider for this subscription
  provider PaymentProvider @default(STRIPE)

  // Auto-renew flag (on by default)
  autoRenew Boolean @default(true)

  // Stripe identifiers
  stripeSubscriptionId    String? @unique
  stripeCheckoutSessionId String?

  // Billing window
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  // Trial
  trialStartedAt DateTime?
  trialEndsAt    DateTime?

  // Cancellation
  cancelAtPeriodEnd  Boolean   @default(false)
  cancelledAt        DateTime?
  cancellationReason String?

  // Scheduled plan change
  scheduledPlanId   String?
  scheduledInterval BillingInterval?

  // M-Pesa specific
  // Number of consecutive renewal failures (resets on success)
  mpesaRenewalAttempts Int      @default(0)
  // When the last STK push was sent for this subscription's renewal
  mpesaLastRenewalAt   DateTime?
  // Grace period end (3 days after currentPeriodEnd for M-Pesa)
  gracePeriodEndsAt    DateTime?
  // Reminder sent flag (reset each billing cycle)
  reminderSentAt       DateTime?

  // Lifecycle timestamps
  activatedAt DateTime?
  expiredAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  logs              SubscriptionLog[]
  payments          Payment[]
  mpesaTransactions MpesaTransaction[]

  @@index([userId])
  @@index([status])
  @@index([provider])
  @@index([stripeSubscriptionId])
  @@index([currentPeriodEnd])
  @@index([gracePeriodEndsAt])
  @@map("subscriptions")
}

// ============================================================
// M-PESA TRANSACTIONS — one record per STK Push attempt
// ============================================================

model MpesaTransaction {
  id             String @id @default(uuid())
  subscriptionId String
  userId         String

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Safaricom Daraja identifiers
  merchantRequestId  String  @unique  // Idempotency key from Daraja
  checkoutRequestId  String  @unique  // Used to query status
  mpesaReceiptNumber String? @unique  // Set on success by callback

  // Payment details
  phoneNumber String
  amountKes   Int     // Amount in KES (whole shillings, M-Pesa doesn't use cents)

  status      MpesaTransactionStatus @default(PENDING)
  resultCode  String?  // "0" = success, other codes = failure reason
  resultDesc  String?  // Human-readable result

  // Retry tracking
  attemptNumber Int      @default(1)   // 1 = first attempt, 2 = first retry, etc.
  isRenewal     Boolean  @default(true) // false = first-time subscription

  // Timestamps
  initiatedAt   DateTime  @default(now())
  completedAt   DateTime? // Set when callback received
  timeoutAt     DateTime? // When we consider this timed out (initiatedAt + 5min)

  @@index([subscriptionId])
  @@index([userId])
  @@index([status])
  @@index([checkoutRequestId])
  @@index([initiatedAt])
  @@map("mpesa_transactions")
}

// ============================================================
// SUBSCRIPTION LOGS — immutable audit trail
// ============================================================

model SubscriptionLog {
  id             String @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  event          SubscriptionEvent
  previousStatus SubscriptionStatus?
  newStatus      SubscriptionStatus?
  metadata       Json    @default("{}")
  ipAddress      String?

  createdAt DateTime @default(now())

  @@index([subscriptionId])
  @@index([event])
  @@index([createdAt])
  @@map("subscription_logs")
}

// ============================================================
// WEBHOOK EVENTS — idempotency guard
// ============================================================

model WebhookEvent {
  id            String   @id @default(uuid())
  // Supports both Stripe event IDs and M-Pesa CheckoutRequestIDs
  externalId    String   @unique
  provider      String   // "stripe" | "mpesa"
  eventType     String
  processedAt   DateTime @default(now())
  responseStatus Int     @default(200)
  error         String?

  @@index([externalId])
  @@index([provider])
  @@index([processedAt])
  @@map("webhook_events")
}

// ============================================================
// PAYMENTS — one record per charge attempt (both providers)
// ============================================================

model Payment {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  provider PaymentProvider @default(STRIPE)

  // Stripe fields
  stripePaymentIntentId String? @unique
  stripeInvoiceId       String? @unique

  // M-Pesa fields
  mpesaTransactionId    String? // References MpesaTransaction.id
  mpesaReceiptNumber    String?

  amountCents    Int      // For Stripe (USD cents) or M-Pesa (KES * 100 for consistency)
  currency       String   @default("USD")
  status         String   // succeeded | failed | refunded | pending

  failureMessage    String?
  refundedAt        DateTime?
  refundAmountCents Int?

  createdAt DateTime @default(now())

  @@index([subscriptionId])
  @@index([provider])
  @@index([status])
  @@map("payments")
}

// ============================================================
// CRON LOCK — prevents duplicate job execution across Vercel
// function invocations (distributed lock using DB)
// ============================================================

model CronLock {
  id        String   @id     // job name e.g. "renewal-reminders"
  lockedAt  DateTime
  expiresAt DateTime          // lock expires after 10 minutes (job timeout)

  @@map("cron_locks")
}

// ============================================================
// CONTENT MODELS (unchanged)
// ============================================================

model Program {
  id            String              @id @default(uuid())
  title         String
  description   String?
  durationWeeks Int                 @default(4)
  daysPerWeek   Int                 @default(3)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  enrollments   ProgramEnrollment[]
  weeks         Week[]

  @@map("programs")
}

model Week {
  id         String  @id @default(uuid())
  weekNumber Int
  title      String?
  programId  String
  program    Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  days       Day[]

  @@map("weeks")
}

model Day {
  id        String        @id @default(uuid())
  dayNumber Int
  title     String?
  weekId    String
  week      Week          @relation(fields: [weekId], references: [id], onDelete: Cascade)
  exercises DayExercise[]

  @@map("days")
}

model DayExercise {
  id         String   @id @default(uuid())
  orderIndex Int
  dayId      String
  exerciseId String
  day        Day      @relation(fields: [dayId], references: [id], onDelete: Cascade)
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([dayId])
  @@index([exerciseId])
  @@map("day_exercises")
}

model Exercise {
  id             String        @id @default(uuid())
  name           String
  caloriesPerMin Float         @default(0)
  description    String?
  category       String
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  logs           WorkoutLog[]
  dayExercises   DayExercise[]

  @@map("exercises")
}

model ProgramEnrollment {
  id            String    @id @default(uuid())
  userId        String
  programId     String
  startDate     DateTime  @default(now())
  currentWeek   Int       @default(1)
  currentDay    Int       @default(1)
  completedDays Int       @default(0)
  isActive      Boolean   @default(true)
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  program       Program   @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@index([userId])
  @@index([isActive])
  @@map("program_enrollments")
}

model WorkoutLog {
  id             String   @id @default(uuid())
  userId         String
  exerciseId     String
  date           DateTime @default(now())
  duration       Int
  sets           Int?
  reps           Int?
  caloriesBurned Float?
  heartRate      Int?
  difficulty     String?
  notes          String?
  completed      Boolean  @default(true)
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise       Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@index([exerciseId])
  @@map("workout_logs")
}

model UserMetrics {
  id               String   @id @default(uuid())
  userId           String
  date             DateTime @default(now())
  weight           Float?
  bodyFat          Float?
  muscleMass       Float?
  bmi              Float?
  restingHeartRate Int?
  notes            String?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@map("user_metrics")
}

model Achievement {
  id          String            @id @default(uuid())
  name        String            @unique
  description String
  icon        String
  category    String
  requirement Json
  points      Int               @default(0)
  createdAt   DateTime          @default(now())
  users       UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model Streak {
  id              String    @id @default(uuid())
  userId          String    @unique
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastWorkoutDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("streaks")
}

model DailyStats {
  id            String   @id @default(uuid())
  date          DateTime @unique @default(now())
  totalUsers    Int      @default(0)
  activeUsers   Int      @default(0)
  newUsers      Int      @default(0)
  totalWorkouts Int      @default(0)
  revenue       Float    @default(0)
  createdAt     DateTime @default(now())

  @@index([date])
  @@map("daily_stats")
}
