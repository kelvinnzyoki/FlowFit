// ============================================================
// FLOWFIT — PRODUCTION PRISMA SCHEMA  v3
// Adds: M-Pesa transaction tracking, renewal metadata,
//       grace period, provider field, cron lock table
// ============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  GRACE_PERIOD
  CANCELLED
  EXPIRED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAUSED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum PaymentProvider {
  STRIPE
  MPESA
  MANUAL
}

enum SubscriptionEvent {
  CREATED
  TRIAL_STARTED
  TRIAL_CONVERTED
  TRIAL_EXPIRED
  ACTIVATED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  UPGRADED
  DOWNGRADE_SCHEDULED
  DOWNGRADE_APPLIED
  CANCEL_SCHEDULED
  CANCELLED
  REACTIVATED
  EXPIRED
  REFUNDED
  WEBHOOK_RECEIVED
  MPESA_STK_INITIATED
  MPESA_STK_SUCCESS
  MPESA_STK_FAILED
  MPESA_RETRY_SCHEDULED
  GRACE_PERIOD_STARTED
  GRACE_PERIOD_EXPIRED
  RENEWAL_REMINDER_SENT
}

enum MpesaTransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  TIMEOUT
}

// ============================================================
// CORE USER & AUTH
// ============================================================

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String
  name            String?
  role            String    @default("USER")
  isEmailVerified Boolean   @default(false)
  lastLogin       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  stripeCustomerId String? @unique
  mpesaPhone       String?

  profile           Profile?
  enrollments       ProgramEnrollment[]
  workoutLogs       WorkoutLog[]
  metrics           UserMetrics[]
  userAchievements  UserAchievement[]
  subscriptions     Subscription[]
  refreshTokens     RefreshToken[]
  mpesaTransactions MpesaTransaction[]
  notifications     Notification[]
  mpesaPhone      String? 
  phoneVerified   Boolean   @default(false)
  phoneVerifiedAt DateTime?
  phoneOtps  PhoneOtp[]

  @@map("users")
}

model PhoneOtp {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone     String   // normalised 254XXXXXXXXX
  codeHash  String   // bcrypt hash of 6-digit code (never store plaintext)
  attempts  Int      @default(0)  // wrong-code attempts (max 3 before void)

  expiresAt DateTime  // 5 minutes after creation
  usedAt    DateTime? // set when code is consumed or voided

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([phone])
  @@index([expiresAt])
  @@map("phone_otps")
}


model Profile {
  id                  String    @id @default(uuid())
  bio                 String?
  firstName           String?
  lastName            String?
  dateOfBirth         DateTime?
  gender              String?
  height              Float?
  weight              Float?
  targetWeight        Float?
  fitnessGoal         String?
  fitnessLevel        String?
  timezone            String?
  avatarUrl           String?
  onboardingCompleted Boolean   @default(false)
  isPublic            Boolean   @default(true)
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  icon      String    @default("🔔")
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([readAt])
  @@index([createdAt])
  @@map("notifications")
}

// ============================================================
// PLANS
// ============================================================

model Plan {
  id          String  @id @default(uuid())
  slug        String  @unique
  name        String
  description String?

  monthlyPriceCents Int @default(0)
  yearlyPriceCents  Int @default(0)

  // M-Pesa prices (in KES whole shillings)
  // FIX-4: These are the CORRECT field names. The service was using
  //        monthlyPriceKes / yearlyPriceKes which do not exist here.
  mpesaMonthlyKes Int @default(0)
  mpesaYearlyKes  Int @default(0)

  stripePriceIdMonthly String? @unique
  stripePriceIdYearly  String? @unique

  trialDays Int @default(0)

  maxWorkoutsPerMonth  Int?
  maxPrograms          Int?
  hasAdvancedAnalytics Boolean @default(false)
  hasPersonalCoaching  Boolean @default(false)
  hasNutritionTracking Boolean @default(false)
  hasOfflineAccess     Boolean @default(false)

  features     Json    @default("[]")
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)
  isPopular    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions     Subscription[]
  // FIX-1b: Added back-relation so Prisma schema is valid (planId relation below).
  mpesaTransactions MpesaTransaction[]

  @@map("plans")
}

// ============================================================
// SUBSCRIPTIONS
// ============================================================

model Subscription {
  id     String @id @default(uuid())
  userId String
  planId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  status   SubscriptionStatus @default(TRIALING)
  interval BillingInterval    @default(MONTHLY)

  provider  PaymentProvider @default(STRIPE)
  autoRenew Boolean         @default(true)

  stripeSubscriptionId    String? @unique
  stripeCheckoutSessionId String?

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  trialStartedAt DateTime?
  trialEndsAt    DateTime?

  cancelAtPeriodEnd  Boolean   @default(false)
  cancelledAt        DateTime?
  cancellationReason String?

  scheduledPlanId   String?
  scheduledInterval BillingInterval?

  mpesaRenewalAttempts Int       @default(0)
  mpesaLastRenewalAt   DateTime?
  gracePeriodEndsAt    DateTime?
  reminderSentAt       DateTime?

  activatedAt DateTime?
  expiredAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  logs              SubscriptionLog[]
  payments          Payment[]
  mpesaTransactions MpesaTransaction[]

  @@index([userId])
  @@index([status])
  @@index([provider])
  @@index([stripeSubscriptionId])
  @@index([currentPeriodEnd])
  @@index([gracePeriodEndsAt])
  @@map("subscriptions")
}

// ============================================================
// M-PESA TRANSACTIONS
// ============================================================

model MpesaTransaction {
  id String @id @default(uuid())

  // FIX-1: subscriptionId is nullable so the migration succeeds against
  //        existing rows that pre-date this field. New rows always supply it.
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  // FIX-1a: planId is now nullable (String?) to match existing rows, and has
  //         a proper @relation so Prisma generates the correct FK + index.
  //         This is the direct fix for the "Null constraint violation on planId" error:
  //         the field was String (NOT NULL) with no default, so any create that
  //         Prisma processed before our fix would fail if planId wasn't recognised.
  planId String?
  plan   Plan?   @relation(fields: [planId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  merchantRequestId  String  @unique
  checkoutRequestId  String  @unique
  mpesaReceiptNumber String? @unique

  phoneNumber String?

  amountKes Int
  status    MpesaTransactionStatus @default(PENDING)
  resultCode String?
  resultDesc String?

  // FIX-2: Added interval field so the service can persist the billing
  //        interval alongside the transaction. Prisma was throwing
  //        "Unknown field `interval`" on every create, which was the
  //        immediate cause of the planId null constraint violation
  //        (the create never completed).
  interval BillingInterval @default(MONTHLY)

  attemptNumber Int     @default(1)
  // FIX-3: isRenewal defaults to false — new subscriptions are not renewals.
  //        Only retry jobs should set this to true.
  isRenewal     Boolean @default(false)

  initiatedAt DateTime  @default(now())
  completedAt DateTime?
  timeoutAt   DateTime?

  @@index([subscriptionId])
  @@index([planId])
  @@index([userId])
  @@index([status])
  @@index([checkoutRequestId])
  @@index([initiatedAt])
  @@map("mpesa_transactions")
}

// ============================================================
// SUBSCRIPTION LOGS
// ============================================================

model SubscriptionLog {
  id             String @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  event          SubscriptionEvent
  previousStatus SubscriptionStatus?
  newStatus      SubscriptionStatus?
  metadata       Json    @default("{}")
  ipAddress      String?

  createdAt DateTime @default(now())

  @@index([subscriptionId])
  @@index([event])
  @@index([createdAt])
  @@map("subscription_logs")
}

// ============================================================
// WEBHOOK EVENTS
// ============================================================

model WebhookEvent {
  id         String @id @default(uuid())
  externalId String @default("") @unique
  provider   String @default("stripe")
  eventType      String
  processedAt    DateTime @default(now())
  responseStatus Int      @default(200)
  error          String?

  @@index([externalId])
  @@index([provider])
  @@index([processedAt])
  @@map("webhook_events")
}

// ============================================================
// PAYMENTS
// ============================================================

model Payment {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  provider PaymentProvider @default(STRIPE)

  stripePaymentIntentId String? @unique
  stripeInvoiceId       String? @unique

  mpesaTransactionId String?
  mpesaReceiptNumber String?

  amountCents    Int
  currency       String @default("USD")
  status         String

  failureMessage    String?
  refundedAt        DateTime?
  refundAmountCents Int?

  createdAt DateTime @default(now())

  @@index([subscriptionId])
  @@index([provider])
  @@index([status])
  @@map("payments")
}

// ============================================================
// CRON LOCK
// ============================================================

model CronLock {
  id        String   @id
  lockedAt  DateTime
  expiresAt DateTime

  @@map("cron_locks")
}

// ============================================================
// OTP CODES
// ============================================================

model OtpCode {
  id        String   @id @default(uuid())
  email     String
  codeHash  String
  purpose   String
  createdAt DateTime @default(now())
  expiresAt DateTime
  usedAt    DateTime?

  @@index([email])
  @@index([email, purpose])
  @@map("otp_codes")
}

// ============================================================
// CONTENT MODELS
// ============================================================

model Program {
  id            String              @id @default(uuid())
  title         String
  description   String?
  durationWeeks Int                 @default(4)
  daysPerWeek   Int                 @default(3)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  enrollments   ProgramEnrollment[]
  weeks         Week[]

  @@map("programs")
}

model Week {
  id         String  @id @default(uuid())
  weekNumber Int
  title      String?
  programId  String
  program    Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  days       Day[]

  @@map("weeks")
}

model Day {
  id        String        @id @default(uuid())
  dayNumber Int
  title     String?
  weekId    String
  week      Week          @relation(fields: [weekId], references: [id], onDelete: Cascade)
  exercises DayExercise[]

  @@map("days")
}

model DayExercise {
  id         String   @id @default(uuid())
  orderIndex Int
  dayId      String
  exerciseId String
  day        Day      @relation(fields: [dayId], references: [id], onDelete: Cascade)
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([dayId])
  @@index([exerciseId])
  @@map("day_exercises")
}

model Exercise {
  id             String        @id @default(uuid())
  name           String
  description    String?
  category       String
  caloriesPerMin Float         @default(0)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  logs           WorkoutLog[]
  dayExercises   DayExercise[]

  @@map("exercises")
}

model ProgramEnrollment {
  id            String    @id @default(uuid())
  userId        String
  programId     String
  startDate     DateTime  @default(now())
  currentWeek   Int       @default(1)
  currentDay    Int       @default(1)
  completedDays Int       @default(0)
  isActive      Boolean   @default(true)
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  program       Program   @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@index([userId])
  @@index([isActive])
  @@map("program_enrollments")
}

model WorkoutLog {
  id             String   @id @default(uuid())
  userId         String
  exerciseId     String
  date           DateTime @default(now())
  duration       Int
  sets           Int?
  reps           Int?
  caloriesBurned Float?
  heartRate      Int?
  difficulty     String?
  notes          String?
  completed      Boolean  @default(true)
  skipped        Boolean  @default(false)
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise       Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@index([exerciseId])
  @@map("workout_logs")
}

model UserMetrics {
  id               String   @id @default(uuid())
  userId           String
  date             DateTime @default(now())
  weight           Float?
  bodyFat          Float?
  muscleMass       Float?
  bmi              Float?
  restingHeartRate Int?
  notes            String?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@map("user_metrics")
}

model Achievement {
  id          String            @id @default(uuid())
  name        String            @unique
  description String
  icon        String
  category    String
  requirement Json
  points      Int               @default(0)
  createdAt   DateTime          @default(now())
  users       UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model Streak {
  id              String    @id @default(uuid())
  userId          String    @unique
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastWorkoutDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("streaks")
}

model DailyStats {
  id            String   @id @default(uuid())
  date          DateTime @unique @default(now())
  totalUsers    Int      @default(0)
  activeUsers   Int      @default(0)
  newUsers      Int      @default(0)
  totalWorkouts Int      @default(0)
  revenue       Float    @default(0)
  createdAt     DateTime @default(now())

  @@index([date])
  @@map("daily_stats")
}
