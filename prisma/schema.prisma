// ============================================================
// FLOWFIT — PRODUCTION PRISMA SCHEMA  v3
// Adds: M-Pesa transaction tracking, renewal metadata,
//       grace period, provider field, cron lock table
// ============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  GRACE_PERIOD   // M-Pesa grace period (3 days after expiry)
  CANCELLED
  EXPIRED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAUSED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum PaymentProvider {
  STRIPE
  MPESA
  MANUAL
}

enum SubscriptionEvent {
  CREATED
  TRIAL_STARTED
  TRIAL_CONVERTED
  TRIAL_EXPIRED
  ACTIVATED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  UPGRADED
  DOWNGRADE_SCHEDULED
  DOWNGRADE_APPLIED
  CANCEL_SCHEDULED
  CANCELLED
  REACTIVATED
  EXPIRED
  REFUNDED
  WEBHOOK_RECEIVED
  // M-Pesa events
  MPESA_STK_INITIATED
  MPESA_STK_SUCCESS
  MPESA_STK_FAILED
  MPESA_RETRY_SCHEDULED
  GRACE_PERIOD_STARTED
  GRACE_PERIOD_EXPIRED
  RENEWAL_REMINDER_SENT
}

enum MpesaTransactionStatus {
  PENDING      // STK Push sent, awaiting callback
  SUCCESS      // Payment confirmed
  FAILED       // User cancelled or timeout
  CANCELLED    // User explicitly cancelled
  TIMEOUT      // No callback received within window
}

// ============================================================
// CORE USER & AUTH
// ============================================================

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String
  name            String?
  role            String    @default("USER")
  isEmailVerified Boolean   @default(false)
  lastLogin       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  stripeCustomerId String? @unique

  // M-Pesa phone number for auto-renewal STK pushes
  mpesaPhone String?

  profile          Profile?
  enrollments      ProgramEnrollment[]
  workoutLogs      WorkoutLog[]
  metrics          UserMetrics[]
  userAchievements UserAchievement[]
  subscriptions    Subscription[]
  refreshTokens    RefreshToken[]
  mpesaTransactions MpesaTransaction[]
  

  @@map("users")
}

model Profile {
  id                  String    @id @default(uuid())
  bio                 String?
  firstName           String?
  lastName            String?
  dateOfBirth         DateTime?
  gender              String?
  height              Float?
  weight              Float?
  targetWeight        Float?
  fitnessGoal         String?
  fitnessLevel        String?
  timezone            String?
  avatarUrl           String?
  onboardingCompleted Boolean   @default(false)
  isPublic            Boolean   @default(true)
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ============================================================
// PLANS
// ============================================================

model Plan {
  id          String  @id @default(uuid())
  slug        String  @unique
  name        String
  description String?

  monthlyPriceCents Int @default(0)
  yearlyPriceCents  Int @default(0)

  // M-Pesa prices (in KES whole shillings)
  mpesaMonthlyKes Int @default(0)
  mpesaYearlyKes  Int @default(0)

  stripePriceIdMonthly String? @unique
  stripePriceIdYearly  String? @unique

  trialDays Int @default(0)

  maxWorkoutsPerMonth  Int?
  maxPrograms          Int?
  hasAdvancedAnalytics Boolean @default(false)
  hasPersonalCoaching  Boolean @default(false)
  hasNutritionTracking Boolean @default(false)
  hasOfflineAccess     Boolean @default(false)

  features     Json    @default("[]")
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)
  isPopular    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

// ============================================================
// SUBSCRIPTIONS
// ============================================================

model Subscription {
  id     String @id @default(uuid())
  userId String
  planId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  status   SubscriptionStatus @default(TRIALING)
  interval BillingInterval    @default(MONTHLY)

  // Payment provider for this subscription
  provider  PaymentProvider @default(STRIPE)

  // Auto-renew flag (on by default; only meaningful for M-Pesa)
  autoRenew Boolean @default(true)

  // Stripe identifiers
  stripeSubscriptionId    String? @unique
  stripeCheckoutSessionId String?

  // Billing window
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  // Trial
  trialStartedAt DateTime?
  trialEndsAt    DateTime?

  // Cancellation
  cancelAtPeriodEnd  Boolean   @default(false)
  cancelledAt        DateTime?
  cancellationReason String?

  // Scheduled plan change
  scheduledPlanId   String?
  scheduledInterval BillingInterval?

  // M-Pesa specific
  mpesaRenewalAttempts Int       @default(0)
  mpesaLastRenewalAt   DateTime?
  gracePeriodEndsAt    DateTime?
  reminderSentAt       DateTime?

  // Lifecycle timestamps
  activatedAt DateTime?
  expiredAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  logs              SubscriptionLog[]
  payments          Payment[]
  mpesaTransactions MpesaTransaction[]

  @@index([userId])
  @@index([status])
  @@index([provider])
  @@index([stripeSubscriptionId])
  @@index([currentPeriodEnd])
  @@index([gracePeriodEndsAt])
  @@map("subscriptions")
}

// ============================================================
// M-PESA TRANSACTIONS — one record per STK Push attempt
// ============================================================

model MpesaTransaction {
  id String @id @default(uuid())

  // FIX: subscriptionId is nullable (String?) so that the migration can
  // succeed against the 28 existing rows that pre-date this field.
  // New rows from /mpesa/initiate always supply a subscriptionId.
  subscriptionId String?
  userId         String

  // FIX: onDelete: SetNull matches the nullable foreign key above.
  // When a subscription is deleted the transaction record is kept for audit.
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Safaricom Daraja identifiers
  merchantRequestId  String  @unique  // Idempotency key from Daraja
  checkoutRequestId  String  @unique  // Used to query status
  mpesaReceiptNumber String? @unique  // Set on success by callback

  // FIX: phoneNumber is nullable (String?) so the migration succeeds against
  // the 28 existing rows. The migration SQL backfills them with 'unknown'.
  // Real phone numbers are written on every new STK push initiation.
  phoneNumber String?

  amountKes   Int                    // Amount in KES (whole shillings)
  status      MpesaTransactionStatus @default(PENDING)
  resultCode  String?
  resultDesc  String?

  // Retry tracking
  attemptNumber Int     @default(1)  // 1 = first attempt, 2 = first retry …
  isRenewal     Boolean @default(true)

  // Timestamps
  initiatedAt DateTime  @default(now())
  completedAt DateTime?
  timeoutAt   DateTime?

  @@index([subscriptionId])
  @@index([userId])
  @@index([status])
  @@index([checkoutRequestId])
  @@index([initiatedAt])
  @@map("mpesa_transactions")
}

// ============================================================
// SUBSCRIPTION LOGS — immutable audit trail
// ============================================================

model SubscriptionLog {
  id             String @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  event          SubscriptionEvent
  previousStatus SubscriptionStatus?
  newStatus      SubscriptionStatus?
  metadata       Json    @default("{}")
  ipAddress      String?

  createdAt DateTime @default(now())

  @@index([subscriptionId])
  @@index([event])
  @@index([createdAt])
  @@map("subscription_logs")
}

// ============================================================
// WEBHOOK EVENTS — idempotency guard
// ============================================================

model WebhookEvent {
  id         String @id @default(uuid())

  // Unique event ID from the provider — idempotency key.
  // Replaces the old stripeEventId field; now supports both Stripe
  // event IDs and M-Pesa CheckoutRequestIDs.
  externalId String @default("") @unique

  // FIX: @default("stripe") lets Prisma generate DEFAULT 'stripe' in the
  // migration SQL so the 283 existing rows are backfilled automatically
  // instead of causing "column NOT NULL has no default" failure.
  // All existing rows ARE Stripe events so this value is correct.
  provider String @default("stripe")  // "stripe" | "mpesa"

  eventType      String
  processedAt    DateTime @default(now())
  responseStatus Int      @default(200)
  error          String?

  @@index([externalId])
  @@index([provider])
  @@index([processedAt])
  @@map("webhook_events")
}

// ============================================================
// PAYMENTS — one record per charge attempt (both providers)
// ============================================================

model Payment {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  provider PaymentProvider @default(STRIPE)

  // Stripe fields
  stripePaymentIntentId String? @unique
  stripeInvoiceId       String? @unique

  // M-Pesa fields
  mpesaTransactionId String?
  mpesaReceiptNumber String?

  amountCents    Int
  currency       String @default("USD")
  status         String // succeeded | failed | refunded | pending

  failureMessage    String?
  refundedAt        DateTime?
  refundAmountCents Int?

  createdAt DateTime @default(now())

  @@index([subscriptionId])
  @@index([provider])
  @@index([status])
  @@map("payments")
}

// ============================================================
// CRON LOCK — distributed lock prevents duplicate job execution
// ============================================================

model CronLock {
  id        String   @id     // job name e.g. "renewal-reminders"
  lockedAt  DateTime
  expiresAt DateTime

  @@map("cron_locks")
}

// ─── OtpCode — stores registration and password-reset verification codes ──────
// Added to support:
//   POST /auth/send-otp        (registration flow)
//   POST /auth/verify-otp      (registration flow)
//   POST /auth/forgot-password (password reset flow)
//   POST /auth/verify-reset-otp (password reset flow)
//
// codeHash: bcrypt hash of the 6-digit code (never store plaintext OTPs)
// purpose: 'registration' | 'password_reset'
// usedAt: set when the code is consumed — prevents replay attacks
// expiresAt: 10 minutes from issuance — short-lived

model OtpCode {
  id        String   @id @default(uuid())
  email     String
  codeHash  String
  purpose   String   // 'registration' | 'password_reset'
  createdAt DateTime @default(now())
  expiresAt DateTime
  usedAt    DateTime?

  @@index([email])
  @@index([email, purpose])
  @@map("otp_codes")
}

// ============================================================
// CONTENT MODELS (unchanged)
// ============================================================

model Program {
  id            String              @id @default(uuid())
  title         String
  description   String?
  durationWeeks Int                 @default(4)
  daysPerWeek   Int                 @default(3)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  enrollments   ProgramEnrollment[]
  weeks         Week[]

  @@map("programs")
}

model Week {
  id         String  @id @default(uuid())
  weekNumber Int
  title      String?
  programId  String
  program    Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  days       Day[]

  @@map("weeks")
}

model Day {
  id        String        @id @default(uuid())
  dayNumber Int
  title     String?
  weekId    String
  week      Week          @relation(fields: [weekId], references: [id], onDelete: Cascade)
  exercises DayExercise[]

  @@map("days")
}

model DayExercise {
  id         String   @id @default(uuid())
  orderIndex Int
  dayId      String
  exerciseId String
  day        Day      @relation(fields: [dayId], references: [id], onDelete: Cascade)
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([dayId])
  @@index([exerciseId])
  @@map("day_exercises")
}

model Exercise {
  id             String        @id @default(uuid())
  name           String
  description    String?
  category       String
  caloriesPerMin Float         @default(0)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  logs           WorkoutLog[]
  dayExercises   DayExercise[]

  @@map("exercises")
}

model ProgramEnrollment {
  id            String    @id @default(uuid())
  userId        String
  programId     String
  startDate     DateTime  @default(now())
  currentWeek   Int       @default(1)
  currentDay    Int       @default(1)
  completedDays Int       @default(0)
  isActive      Boolean   @default(true)
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  program       Program   @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@index([userId])
  @@index([isActive])
  @@map("program_enrollments")
}

model WorkoutLog {
  id             String   @id @default(uuid())
  userId         String
  exerciseId     String
  date           DateTime @default(now())
  duration       Int
  sets           Int?
  reps           Int?
  caloriesBurned Float?
  heartRate      Int?
  difficulty     String?
  notes          String?
  completed      Boolean  @default(true)
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise       Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@index([exerciseId])
  @@map("workout_logs")
}

model UserMetrics {
  id               String   @id @default(uuid())
  userId           String
  date             DateTime @default(now())
  weight           Float?
  bodyFat          Float?
  muscleMass       Float?
  bmi              Float?
  restingHeartRate Int?
  notes            String?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@map("user_metrics")
}

model Achievement {
  id          String            @id @default(uuid())
  name        String            @unique
  description String
  icon        String
  category    String
  requirement Json
  points      Int               @default(0)
  createdAt   DateTime          @default(now())
  users       UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model Streak {
  id              String    @id @default(uuid())
  userId          String    @unique
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastWorkoutDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("streaks")
}

model DailyStats {
  id            String   @id @default(uuid())
  date          DateTime @unique @default(now())
  totalUsers    Int      @default(0)
  activeUsers   Int      @default(0)
  newUsers      Int      @default(0)
  totalWorkouts Int      @default(0)
  revenue       Float    @default(0)
  createdAt     DateTime @default(now())

  @@index([date])
  @@map("daily_stats")
}
